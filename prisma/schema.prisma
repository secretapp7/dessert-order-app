generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AdminRole {
  OWNER
  STAFF
}

enum ProductStatus {
  ACTIVE
  SOLD_OUT
  HIDDEN
}

enum ProductImageType {
  MAIN
  FEATURED
  CLOSEUP
  TRAY
  GALLERY
}

enum AppLanguage {
  EN
  AR
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  NONE
  PENDING
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum ExpenseCategory {
  INGREDIENTS
  PACKAGING
  DELIVERY
  MARKETING
  TOOLS
  OTHER
}

enum ReviewStatus {
  APPROVED
  PENDING
  HIDDEN
}

enum InventoryItemType {
  INGREDIENT
  PACKAGING
  SUPPLY
  TOOL
  OTHER
}

enum InventoryUnit {
  GRAM
  KILOGRAM
  MILLILITER
  LITER
  PIECE
  PACK
  BOX
  BAG
  BOTTLE
  CAN
  OTHER
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  WASTE
  RESERVED
  RELEASED
  MANUAL_CORRECTION
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

model Customer {
  id                String    @id @default(cuid())
  name              String
  phone             String
  email             String?
  notes             String?
  /// Admin-only CRM note (not shown to customers).
  internalNote      String?   @db.Text
  /// Comma-separated admin tags.
  tags              String?   @db.Text
  preferredLanguage String?
  lastContactedAt   DateTime?
  isVip             Boolean   @default(false)
  isBlocked         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders Order[]

  @@index([phone])
  @@index([isVip])
  @@index([isBlocked])
  @@map("customers")
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id           String          @id @default(cuid())
  slug         String          @unique
  nameEn       String
  nameAr       String
  descriptionEn String
  descriptionAr String
  categoryId   String?
  status       ProductStatus   @default(ACTIVE)
  badgeEn      String?
  badgeAr      String?
  featured     Boolean         @default(false)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sizes    ProductSize[]
  images   ProductImage[]
  reviews  Review[]
  orderItems OrderItem[]

  @@index([status])
  @@map("products")
}

model ProductSize {
  id                 String   @id @default(cuid())
  productId          String
  labelEn            String
  labelAr            String
  servesEn           String
  servesAr           String
  priceOmr           Decimal  @default(0) @db.Decimal(12, 3)
  ingredientCostOmr  Decimal  @default(0) @db.Decimal(12, 3)
  packagingCostOmr   Decimal  @default(0) @db.Decimal(12, 3)
  laborCostOmr       Decimal  @default(0) @db.Decimal(12, 3)
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_sizes")
}

model ProductImage {
  id        String           @id @default(cuid())
  productId String
  type      ProductImageType
  url       String
  altEn     String?
  altAr     String?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Offer {
  id              String    @id @default(cuid())
  slug            String    @unique
  titleEn         String
  titleAr         String
  descriptionEn   String
  descriptionAr   String
  priceOmr        Decimal   @db.Decimal(12, 3)
  imageUrl        String?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean   @default(true)
  featuredOnHome  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("offers")
}

model Order {
  id                   String             @id @default(cuid())
  publicId             String             @unique @default(cuid())
  customerId           String?
  customerName         String
  customerPhone        String
  language             AppLanguage
  fulfillmentMethod    FulfillmentMethod
  orderStatus          OrderStatus        @default(NEW)
  deliveryStatus       DeliveryStatus     @default(NONE)
  paymentStatus        PaymentStatus      @default(UNPAID)
  dateNeeded           DateTime           @db.Date
  notes                String?
  mapsLink             String?
  gpsLatitude          Decimal?           @db.Decimal(10, 7)
  gpsLongitude         Decimal?           @db.Decimal(10, 7)
  gpsAccuracy          Decimal?           @db.Decimal(12, 3)
  addressDetails       String?
  dessertSubtotalOmr   Decimal            @db.Decimal(12, 3)
  deliveryFeeOmr       Decimal?           @db.Decimal(12, 3)
  totalOmr             Decimal            @db.Decimal(12, 3)
  whatsappMessage      String             @db.Text
  cancelReason         String?
  /// When set, the order is hidden from default admin lists unless “Archived” filter is chosen.
  archivedAt           DateTime?
  adminNote            String?            @db.Text
  /// Secure token for customer review link (`/review/{publicId}?token=…`).
  reviewToken          String?            @unique
  reviewRequestedAt    DateTime?
  reviewedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([createdAt])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([fulfillmentMethod])
  @@index([dateNeeded])
  @@index([customerPhone])
  @@index([archivedAt])
  @@map("orders")
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  productId             String?
  productSizeId         String?
  productNameEn         String
  productNameAr         String
  sizeLabelEn           String
  sizeLabelAr           String
  quantity              Int
  unitPriceOmr          Decimal  @db.Decimal(12, 3)
  lineTotalOmr          Decimal  @db.Decimal(12, 3)
  estimatedUnitCostOmr  Decimal  @default(0) @db.Decimal(12, 3)
  estimatedLineProfitOmr Decimal @default(0) @db.Decimal(12, 3)
  createdAt             DateTime @default(now())

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  productSize ProductSize? @relation(fields: [productSizeId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Expense {
  id          String           @id @default(cuid())
  category    ExpenseCategory
  title       String
  amountOmr   Decimal          @db.Decimal(12, 3)
  expenseDate DateTime         @db.Date
  notes       String?
  /// When set, the expense is excluded from profit totals (voided / cancelled entry).
  voidedAt    DateTime?
  voidReason  String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([expenseDate])
  @@index([voidedAt])
  @@map("expenses")
}

/// Key/value pairs for production capacity & notice rules (see seed defaults).
model AvailabilitySetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("availability_settings")
}

/// Blocks ordering for every calendar day overlapping [startsAt, endsAt] (inclusive overlap semantics).
model ClosedDate {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reasonEn  String?
  reasonAr  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt])
  @@index([isActive, endsAt])
  @@map("closed_dates")
}

/// Per-calendar-day max orders (UTC date). Active overrides beat global default limit.
model DailyCapacityOverride {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  maxOrders Int
  noteEn    String?
  noteAr    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, date])
  @@map("daily_capacity_overrides")
}

model Review {
  id               String       @id @default(cuid())
  productId        String?
  customerName     String
  customerNameAr   String?
  customerInitials String
  rating           Int
  textEn           String       @db.Text
  textAr           String?      @db.Text
  source           String?
  verifiedOrder    Boolean      @default(false)
  featured         Boolean      @default(false)
  sortOrder        Int          @default(0)
  reviewDate       DateTime?    @db.Date
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
  @@index([featured])
  @@index([sortOrder])
  @@map("reviews")
}

model BusinessSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_settings")
}

model InventoryCategory {
  id          String            @id @default(cuid())
  nameEn      String
  nameAr      String?
  slug        String            @unique
  type        InventoryItemType
  description String?
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items InventoryItem[]

  @@index([type, isActive])
  @@map("inventory_categories")
}

model InventoryItem {
  id                 String            @id @default(cuid())
  categoryId         String?
  type               InventoryItemType
  nameEn             String
  nameAr             String?
  sku                String?           @unique
  unit               InventoryUnit
  currentQuantity    Decimal           @default(0) @db.Decimal(12, 3)
  lowStockThreshold  Decimal?          @db.Decimal(12, 3)
  reorderQuantity    Decimal?          @db.Decimal(12, 3)
  averageUnitCostOmr Decimal?          @db.Decimal(12, 3)
  supplierName       String?
  supplierContact    String?
  storageLocation    String?
  notes              String?           @db.Text
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  category  InventoryCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@index([type, isActive])
  @@index([categoryId])
  @@index([nameEn])
  @@index([currentQuantity])
  @@map("inventory_items")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  itemId        String
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(12, 3)
  unit          InventoryUnit
  unitCostOmr   Decimal?              @db.Decimal(12, 3)
  totalCostOmr  Decimal?              @db.Decimal(12, 3)
  reason        String?
  referenceType String?
  referenceId   String?
  movementDate  DateTime              @default(now())
  createdAt     DateTime              @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, movementDate])
  @@index([type, movementDate])
  @@map("inventory_movements")
}
